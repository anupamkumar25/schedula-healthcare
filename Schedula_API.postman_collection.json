    {
      "name": "Analytics",
      "description": "Operational insights: overview, doctor-specific, and queue analytics. Use from/to date filters. JWT required.",
      "item": [
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/analytics/overview?from={{from_date}}&to={{to_date}}",
              "host": ["{{base_url}}"],
              "path": ["analytics", "overview"],
              "query": [
                { "key": "from", "value": "{{from_date}}" },
                { "key": "to", "value": "{{to_date}}" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Doctor Analytics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/analytics/doctor?doctorId={{doctor_id}}&from={{from_date}}&to={{to_date}}",
              "host": ["{{base_url}}"],
              "path": ["analytics", "doctor"],
              "query": [
                { "key": "doctorId", "value": "{{doctor_id}}" },
                { "key": "from", "value": "{{from_date}}" },
                { "key": "to", "value": "{{to_date}}" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Queue Analytics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/analytics/queue?from={{from_date}}&to={{to_date}}",
              "host": ["{{base_url}}"],
              "path": ["analytics", "queue"],
              "query": [
                { "key": "from", "value": "{{from_date}}" },
                { "key": "to", "value": "{{to_date}}" }
              ]
            }
          },
          "response": []
        }
      ]
    },
